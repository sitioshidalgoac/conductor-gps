<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>SHidalgo Kué'in — Tu Taxi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
:root{--bg:#f7f8fc;--bg2:#fff;--bg3:#eef1f8;--primary:#1a56db;--primary2:#1239a0;--pl:#e8efff;--accent:#ff6b2b;--green:#16a34a;--gl:#dcfce7;--text:#111827;--text2:#6b7280;--border:#e5e7eb;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--text);font-family:"Nunito",sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden;}

.splash{position:fixed;inset:0;background:linear-gradient(160deg,var(--primary),var(--primary2));z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;transition:opacity 0.5s;}
.splash.hide{opacity:0;pointer-events:none;}
.splash-logo{width:120px;height:120px;object-fit:contain;border-radius:50%;border:3px solid rgba(255,255,255,0.6);box-shadow:0 0 40px rgba(0,0,0,0.3);animation:floatY 2s ease-in-out infinite;}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.splash-title{font-size:30px;font-weight:900;color:#fff;letter-spacing:-0.5px;}
.splash-sub{font-size:13px;color:rgba(255,255,255,0.75);font-weight:600;}
.splash-org{font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:2px;}
.splash-bar{width:50px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;overflow:hidden;margin-top:10px;}
.splash-fill{height:100%;background:#fff;border-radius:2px;animation:fill 2.2s ease-in-out forwards;}
@keyframes fill{0%{width:0%}100%{width:100%}}

.login-screen{position:fixed;inset:0;background:#fff;z-index:8888;display:none;flex-direction:column;align-items:center;justify-content:center;padding:32px;gap:14px;overflow-y:auto;}
.login-screen.show{display:flex;}
.login-logo{width:90px;height:90px;object-fit:contain;border-radius:50%;border:2px solid var(--border);box-shadow:0 4px 20px rgba(0,0,0,0.1);}
.login-title{font-size:26px;font-weight:900;color:var(--text);text-align:center;}
.login-hint{font-size:14px;color:var(--text2);text-align:center;margin-top:-8px;}
.login-org{font-size:11px;color:var(--primary);text-align:center;font-weight:700;text-transform:uppercase;letter-spacing:1px;}
.login-inp{width:100%;max-width:320px;border:2px solid var(--border);border-radius:12px;padding:13px 16px;font-family:"Nunito",sans-serif;font-size:16px;color:var(--text);}
.login-inp:focus{outline:none;border-color:var(--primary);}
.login-btn{width:100%;max-width:320px;background:var(--primary);color:#fff;border:none;border-radius:12px;padding:15px;font-family:"Nunito",sans-serif;font-size:17px;font-weight:800;cursor:pointer;box-shadow:0 4px 16px rgba(26,86,219,0.35);}
.login-btn:active{transform:scale(0.98);}
.skip-btn{color:var(--text2);font-size:13px;cursor:pointer;text-decoration:underline;background:none;border:none;font-family:"Nunito",sans-serif;}

.header{background:var(--primary);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.hdr-logo-row{display:flex;align-items:center;gap:8px;}
.hdr-logo-img{width:32px;height:32px;object-fit:contain;border-radius:50%;border:2px solid rgba(255,255,255,0.5);}
.hdr-text{font-size:17px;font-weight:900;color:#fff;}
.hdr-sub{font-size:9px;color:rgba(255,255,255,0.7);font-weight:600;}
.hdr-user{background:rgba(255,255,255,0.18);border-radius:20px;padding:5px 11px;font-size:13px;font-weight:700;color:#fff;}

.map-section{flex:1;position:relative;overflow:hidden;}
#map{width:100%;height:100%;}

.bottom-sheet{position:absolute;bottom:0;left:0;right:0;background:#fff;border-radius:20px 20px 0 0;box-shadow:0 -8px 40px rgba(0,0,0,0.12);z-index:1000;}
.sheet-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:10px auto 0;}
.sheet-content{padding:14px 16px 16px;}
.sheet-title{font-size:15px;font-weight:800;margin-bottom:10px;}
.disp-row{display:flex;gap:10px;margin-bottom:12px;}
.disp-card{flex:1;background:var(--pl);border-radius:12px;padding:10px;text-align:center;}
.disp-num{font-size:26px;font-weight:900;color:var(--primary);}
.disp-label{font-size:10px;color:var(--text2);font-weight:600;}
.disp-card.oj{background:#fff5f0;}.disp-card.oj .disp-num{color:var(--accent);}
.btn-solicitar{width:100%;background:linear-gradient(135deg,var(--primary),var(--primary2));color:#fff;border:none;border-radius:14px;padding:15px;font-family:"Nunito",sans-serif;font-size:17px;font-weight:800;cursor:pointer;box-shadow:0 4px 18px rgba(26,86,219,0.35);display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:10px;}
.btn-solicitar:active{transform:scale(0.98);}
.btn-solicitar:disabled{background:#e5e7eb;color:#9ca3af;box-shadow:none;}
.bases-row{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;}
.bases-row::-webkit-scrollbar{display:none;}
.base-chip{flex-shrink:0;background:var(--bg3);border-radius:20px;padding:5px 11px;font-size:11px;font-weight:700;color:var(--text2);cursor:pointer;border:2px solid transparent;white-space:nowrap;}
.base-chip.sel{background:var(--pl);border-color:var(--primary);color:var(--primary);}

.screen{display:none;flex:1;flex-direction:column;overflow:hidden;}
.screen.active{display:flex;}
.hist-wrap{flex:1;overflow-y:auto;padding:16px;}
.hist-head{font-size:20px;font-weight:900;margin-bottom:14px;}
.hist-item{background:#fff;border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.hist-dest{font-size:15px;font-weight:800;}
.hist-meta{font-size:12px;color:var(--text2);margin-top:4px;}

.bottom-nav{display:flex;background:#fff;border-top:1px solid var(--border);flex-shrink:0;padding:4px 0;}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px;border:none;background:transparent;cursor:pointer;color:var(--text2);}
.nav-btn.active{color:var(--primary);}
.nav-icon{font-size:21px;}
.nav-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}

.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:9000;display:none;align-items:flex-end;backdrop-filter:blur(4px);}
.modal-ov.open{display:flex;}
.modal-sheet{background:#fff;border-radius:20px 20px 0 0;padding:24px;width:100%;}
.modal-logo-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.modal-logo{width:44px;height:44px;object-fit:contain;border-radius:50%;border:2px solid var(--border);}
.modal-title{font-size:20px;font-weight:900;}
.modal-sub{font-size:13px;color:var(--text2);margin-bottom:16px;}
.form-inp{width:100%;border:2px solid var(--border);border-radius:12px;padding:12px 14px;font-family:"Nunito",sans-serif;font-size:15px;color:var(--text);margin-bottom:10px;}
.form-inp:focus{outline:none;border-color:var(--primary);}
.modal-btns{display:flex;gap:10px;margin-top:4px;}
.modal-btn{flex:1;padding:13px;border-radius:12px;border:none;cursor:pointer;font-family:"Nunito",sans-serif;font-size:15px;font-weight:800;}
.modal-btn.pri{background:var(--primary);color:#fff;}
.modal-btn.sec{background:var(--bg3);color:var(--text2);}

.viaje-ov{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:8500;display:none;align-items:flex-end;backdrop-filter:blur(4px);}
.viaje-ov.show{display:flex;}
.viaje-card{background:#fff;border-radius:20px 20px 0 0;padding:24px;width:100%;}
.viaje-check{font-size:12px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;}
.viaje-taxi-row{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.viaje-taxi-ic{font-size:40px;background:var(--pl);width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
.viaje-taxi-id{font-size:22px;font-weight:900;color:var(--primary);}
.viaje-taxi-cond{font-size:13px;color:var(--text2);font-weight:600;}
.viaje-taxi-badge{font-size:12px;padding:3px 9px;background:var(--gl);color:var(--green);border-radius:20px;font-weight:700;display:inline-block;margin-top:4px;}
.viaje-dest-box{background:var(--bg3);border-radius:12px;padding:12px 14px;margin-bottom:14px;}
.viaje-dest-lbl{font-size:10px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:1px;}
.viaje-dest-txt{font-size:16px;font-weight:800;margin-top:4px;}
.cancel-btn{width:100%;background:var(--bg3);color:var(--text2);border:none;border-radius:12px;padding:13px;font-family:"Nunito",sans-serif;font-size:15px;font-weight:700;cursor:pointer;}

.rate-ov{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9500;display:none;align-items:center;justify-content:center;padding:24px;}
.rate-ov.show{display:flex;}
.rate-card{background:#fff;border-radius:20px;padding:28px;width:100%;max-width:340px;text-align:center;}
.rate-logo{width:60px;height:60px;object-fit:contain;border-radius:50%;border:2px solid var(--border);margin-bottom:10px;}
.rate-title{font-size:20px;font-weight:900;margin-bottom:4px;}
.rate-sub{font-size:13px;color:var(--text2);margin-bottom:18px;}
.stars{display:flex;justify-content:center;gap:10px;margin-bottom:18px;}
.star{font-size:34px;cursor:pointer;filter:grayscale(1);transition:filter 0.15s;}
.star.on{filter:none;}
.rate-btn{width:100%;background:var(--primary);color:#fff;border:none;border-radius:12px;padding:13px;font-family:"Nunito",sans-serif;font-size:16px;font-weight:800;cursor:pointer;}

.toast{position:fixed;top:76px;left:50%;transform:translateX(-50%);background:var(--text);color:#fff;padding:10px 20px;border-radius:20px;font-size:13px;font-weight:600;z-index:99999;opacity:0;transition:opacity 0.3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-thumb{background:var(--border);}
</style>
</head>
<body>

<div class="splash" id="splash">
  <img class="splash-logo" src="data:image/jpeg;base64," alt="Sitios Hidalgo">
  <div class="splash-title">SHidalgo Kué'in</div>
  <div class="splash-sub">Tu taxi de confianza</div>
  <div class="splash-org">Sitios Hidalgo A.C. • Nochixtlán</div>
  <div class="splash-bar"><div class="splash-fill"></div></div>
</div>

<div class="login-screen" id="login-screen">
  <img class="login-logo" src="data:image/jpeg;base64," alt="Sitios Hidalgo">
  <div class="login-title">¡Bienvenido!</div>
  <div class="login-hint">Pide tu taxi en Nochixtlán</div>
  <div class="login-org">Sitios Hidalgo A.C.</div>
  <input class="login-inp" id="login-name" placeholder="¿Cómo te llamas?" maxlength="30">
  <input class="login-inp" id="login-phone" placeholder="Teléfono (opcional)" type="tel" maxlength="15">
  <button class="login-btn" onclick="doLogin()">Comenzar 🚀</button>
  <button class="skip-btn" onclick="doLogin(true)">Continuar sin registrarme</button>
</div>

<div class="header" id="app-header" style="display:none">
  <div class="hdr-logo-row">
    <img class="hdr-logo-img" src="data:image/jpeg;base64," alt="">
    <div>
      <div class="hdr-text">SHidalgo Kué'in</div>
      <div class="hdr-sub">Nochixtlán, Oaxaca</div>
    </div>
  </div>
  <div class="hdr-user" id="hdr-user">Usuario</div>
</div>

<div class="screen active" id="screen-inicio">
  <div class="map-section">
    <div id="map"></div>
    <div class="bottom-sheet">
      <div class="sheet-handle"></div>
      <div class="sheet-content">
        <div class="sheet-title">🚖 Taxis disponibles ahora</div>
        <div class="disp-row">
          <div class="disp-card"><div class="disp-num" id="cnt-libres">—</div><div class="disp-label">Libres</div></div>
          <div class="disp-card oj"><div class="disp-num" id="cnt-ocupados">—</div><div class="disp-label">Ocupados</div></div>
          <div class="disp-card"><div class="disp-num" id="cnt-cerca">—</div><div class="disp-label">Cerca</div></div>
        </div>
        <button class="btn-solicitar" id="btn-solicitar" onclick="abrirSolicitud()">🚖 Solicitar Taxi</button>
        <div style="font-size:11px;color:var(--text2);margin-bottom:7px;font-weight:700;">Bases:</div>
        <div class="bases-row" id="bases-row"></div>
      </div>
    </div>
  </div>
</div>

<div class="screen" id="screen-historial">
  <div class="hist-wrap">
    <div class="hist-head">📋 Mis viajes</div>
    <div id="hist-list"></div>
  </div>
</div>

<div class="bottom-nav" id="bottom-nav" style="display:none">
  <button class="nav-btn active" onclick="switchNav('inicio',this)"><div class="nav-icon">🏠</div><div class="nav-label">Inicio</div></button>
  <button class="nav-btn" onclick="switchNav('historial',this)"><div class="nav-icon">📋</div><div class="nav-label">Mis viajes</div></button>
</div>

<div class="modal-ov" id="modal-sol">
  <div class="modal-sheet">
    <div class="modal-logo-row">
      <img class="modal-logo" src="data:image/jpeg;base64," alt="">
      <div>
        <div class="modal-title">Solicitar Taxi</div>
      </div>
    </div>
    <div class="modal-sub">Te enviamos el taxi libre más cercano</div>
    <input class="form-inp" id="sol-destino" placeholder="¿A dónde vas?">
    <input class="form-inp" id="sol-ref" placeholder="Referencia (opcional)">
    <div class="modal-btns">
      <button class="modal-btn pri" onclick="solicitarTaxi()">Solicitar ahora</button>
      <button class="modal-btn sec" onclick="cerrarModal()">Cancelar</button>
    </div>
  </div>
</div>

<div class="viaje-ov" id="viaje-ov">
  <div class="viaje-card">
    <div class="viaje-check">✓ Taxi en camino</div>
    <div class="viaje-taxi-row">
      <div class="viaje-taxi-ic">🚖</div>
      <div>
        <div class="viaje-taxi-id" id="v-taxi-id">T-01</div>
        <div class="viaje-taxi-cond" id="v-taxi-cond">Conductor</div>
        <div class="viaje-taxi-badge">En camino</div>
      </div>
    </div>
    <div class="viaje-dest-box">
      <div class="viaje-dest-lbl">📍 Destino</div>
      <div class="viaje-dest-txt" id="v-destino">—</div>
    </div>
    <button class="cancel-btn" onclick="cancelarSolicitud()">Cancelar solicitud</button>
  </div>
</div>

<div class="rate-ov" id="rate-ov">
  <div class="rate-card">
    <img class="rate-logo" src="data:image/jpeg;base64," alt="">
    <div class="rate-title">¿Cómo estuvo tu viaje?</div>
    <div class="rate-sub" id="rate-sub">Califica a tu conductor</div>
    <div class="stars" id="stars">
      <span class="star" onclick="rateStar(1)">⭐</span>
      <span class="star" onclick="rateStar(2)">⭐</span>
      <span class="star" onclick="rateStar(3)">⭐</span>
      <span class="star" onclick="rateStar(4)">⭐</span>
      <span class="star" onclick="rateStar(5)">⭐</span>
    </div>
    <button class="rate-btn" onclick="enviarRating()">Enviar calificación</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script type="module">
import{initializeApp}from"https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
import{getDatabase,ref,onValue,push,set}from"https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";
import{getFirestore,collection,addDoc,doc,onSnapshot,updateDoc,serverTimestamp}from"https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";
const FC={apiKey:"AIzaSyDEu6dOk9mUqXp52lyY6vBEm4GAsgU0ESU",authDomain:"sitios-hidalgo-gps.firebaseapp.com",databaseURL:"https://sitios-hidalgo-gps-default-rtdb.firebaseio.com",projectId:"sitios-hidalgo-gps",storageBucket:"sitios-hidalgo-gps.firebasestorage.app",messagingSenderId:"140903781731",appId:"1:140903781731:web:2178219a57a3244db42f56"};
const fapp=initializeApp(FC);const db=getDatabase(fapp);const fs=getFirestore(fapp);
const /* GEOCERCAS — Calibradas en campo con SW Maps — 21/03/2026 — 7/7 ✅ */
BASES=[{id:"B1",nombre:"Centro",                  lat:17.459468,lng:-97.225268,radio:80},{id:"B2",nombre:"Turístico",               lat:17.460197,lng:-97.229843,radio:80},{id:"B3",nombre:"Terminal Sur",            lat:17.460377,lng:-97.231048,radio:100},{id:"B4",nombre:"Porfirio Díaz / Alcalá",  lat:17.458817,lng:-97.222210,radio:80},{id:"B5",nombre:"Porfirio Díaz / 5 de Feb",lat:17.459680,lng:-97.227145,radio:80},{id:"B6",nombre:"Hospital",                lat:17.450427,lng:-97.225592,radio:100},{id:"B7",nombre:"Fresno",                  lat:17.453626,lng:-97.230098,radio:80}];
let myName="Usuario",myPhone="",myLat=17.4575,myLng=-97.2273;
let map,myMark,unidades={},mks={};
let activeSolId=null,activeViaje=null,unsubSol=null,rateData=null,star=5;
let historial=JSON.parse(localStorage.getItem("sh_historial")||"[]");
function dist(a,b,c,d){const R=6371000,dL=(c-a)*Math.PI/180,dG=(d-b)*Math.PI/180,x=Math.sin(dL/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dG/2)**2;return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
setTimeout(()=>{document.getElementById("splash").classList.add("hide");setTimeout(()=>document.getElementById("login-screen").classList.add("show"),500);},2300);
window.doLogin=function(skip=false){
  myName=skip?"Usuario":(document.getElementById("login-name").value.trim()||"Usuario");
  myPhone=skip?"":(document.getElementById("login-phone").value.trim()||"");
  document.getElementById("login-screen").classList.remove("show");
  document.getElementById("app-header").style.display="flex";
  document.getElementById("bottom-nav").style.display="flex";
  document.getElementById("hdr-user").textContent=myName;
  initMap();initFirebase();startMyLoc();renderBases();renderHist();
};
function initMap(){map=L.map("map",{zoomControl:false,attributionControl:false}).setView([17.4575,-97.2273],14);L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{maxZoom:19}).addTo(map);BASES.forEach(b=>{L.circle([b.lat,b.lng],{radius:b.radio,color:"#1a56db",fillColor:"#1a56db",fillOpacity:0.06,weight:1.5,dashArray:"4"}).addTo(map);L.marker([b.lat,b.lng],{icon:L.divIcon({html:`<div style="background:#1a56db;color:#fff;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.2)">${b.nombre}</div>`,className:"",iconAnchor:[0,0]})}).addTo(map);});}
function startMyLoc(){navigator.geolocation?.watchPosition(p=>{myLat=p.coords.latitude;myLng=p.coords.longitude;if(!myMark){myMark=L.marker([myLat,myLng],{icon:L.divIcon({html:`<div style="width:14px;height:14px;background:#1a56db;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 4px rgba(26,86,219,0.25)"></div>`,className:"",iconSize:[14,14],iconAnchor:[7,7]})}).addTo(map);map.setView([myLat,myLng],16);}else myMark.setLatLng([myLat,myLng]);updCerca();},{enableHighAccuracy:true,maximumAge:5000});}
function updCerca(){const c=Object.values(unidades).filter(u=>u.status?.toLowerCase()==="libre"&&u.lat&&u.lng&&dist(myLat,myLng,u.lat,u.lng)<500).length;document.getElementById("cnt-cerca").textContent=c;}
function initFirebase(){onValue(ref(db,"unidades"),snap=>{const d=snap.val()||{};unidades={};Object.entries(d).forEach(([id,u])=>{unidades[id]={...u,id};});const lib=Object.values(unidades).filter(u=>u.status?.toLowerCase()==="libre"&&u.online!==false);const ocp=Object.values(unidades).filter(u=>u.status?.toLowerCase()==="ocupado");document.getElementById("cnt-libres").textContent=lib.length;document.getElementById("cnt-ocupados").textContent=ocp.length;document.getElementById("btn-solicitar").disabled=lib.length===0;updCerca();Object.keys(mks).forEach(id=>{if(!d[id]){map.removeLayer(mks[id]);delete mks[id];}});Object.entries(unidades).forEach(([id,u])=>{if(!u.lat||!u.lng)return;const ok=u.status?.toLowerCase()==="libre"&&u.online!==false;const ic=L.divIcon({html:`<div style="background:${ok?"#16a34a":"#9ca3af"};width:${ok?28:20}px;height:${ok?28:20}px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:${ok?13:10}px;border:2px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.18);opacity:${u.online!==false?1:0.4}">🚖</div>`,className:"",iconSize:[ok?28:20,ok?28:20],iconAnchor:[ok?14:10,ok?14:10]});if(mks[id])mks[id].setLatLng([u.lat,u.lng]).setIcon(ic);else mks[id]=L.marker([u.lat,u.lng],{icon:ic}).addTo(map).bindPopup(`<b>${id}</b><br>${u.conductor||""}<br><b>${u.status}</b>`);});});}
function renderBases(){const row=document.getElementById("bases-row");row.innerHTML=BASES.map(b=>`<div class="base-chip" onclick="selBase('${b.id}',this)">${b.nombre}</div>`).join("");}
window.selBase=function(id,el){document.querySelectorAll(".base-chip").forEach(c=>c.classList.remove("sel"));el.classList.add("sel");const b=BASES.find(x=>x.id===id);if(b)map.setView([b.lat,b.lng],16);};
window.abrirSolicitud=function(){document.getElementById("modal-sol").classList.add("open");document.getElementById("sol-destino").focus();};
window.cerrarModal=function(){document.getElementById("modal-sol").classList.remove("open");};
window.solicitarTaxi=async function(){
  const dest=document.getElementById("sol-destino").value.trim();
  const refTxt=document.getElementById("sol-ref").value.trim();
  if(!dest){showToast("Escribe tu destino");return;}
  const lib=Object.values(unidades).filter(u=>u.status?.toLowerCase()==="libre"&&u.online!==false&&u.lat&&u.lng);
  if(!lib.length){showToast("No hay taxis disponibles");return;}
  const cerca=lib.reduce((a,b)=>dist(myLat,myLng,a.lat,a.lng)<dist(myLat,myLng,b.lat,b.lng)?a:b);
  try{
    const solRef=await addDoc(collection(fs,"solicitudes"),{
      clienteNombre:   myName,
      clienteTelefono: myPhone,
      clienteId:       null,
      unidadId:        cerca.id,
      estado:          "enviado",
      activa:          true,
      lat:             myLat,
      lng:             myLng,
      destinoLabel:    dest+(refTxt?` (${refTxt})`:""),
      destinoLat:      null,
      destinoLng:      null,
      tarifaEstimada:  null,
      hora:            serverTimestamp(),
      actualizadoEn:   serverTimestamp(),
    });
    activeSolId=solRef.id;
    activeViaje={unitId:cerca.id,destino:dest,conductor:cerca.conductor||cerca.name||"Conductor"};
    const hItem={destino:dest,conductor:cerca.conductor||"Conductor",unitId:cerca.id,ts:Date.now()};
    historial.push(hItem);localStorage.setItem("sh_historial",JSON.stringify(historial.slice(-50)));
    cerrarModal();
    document.getElementById("v-taxi-id").textContent=cerca.id;
    document.getElementById("v-taxi-cond").textContent=cerca.conductor||"Conductor";
    document.getElementById("v-destino").textContent=dest+(refTxt?` (${refTxt})`:"");
    document.getElementById("viaje-ov").classList.add("show");
    showToast("Taxi "+cerca.id+" asignado — "+Math.round(dist(myLat,myLng,cerca.lat,cerca.lng))+"m");
    escucharSolicitud(solRef.id,cerca.id);
  }catch(e){console.error("[Solicitud]",e);showToast("Error al solicitar — verifica tu conexión");}
};
function escucharSolicitud(solId,unitId){
  if(unsubSol){unsubSol();unsubSol=null;}
  unsubSol=onSnapshot(doc(fs,"solicitudes",solId),snap=>{
    if(!snap.exists())return;
    const d=snap.data();
    if(d.estado==="aceptado"){
      document.querySelector(".viaje-check").textContent="Conductor aceptó — en camino";
      document.querySelector(".viaje-taxi-badge").textContent="Aceptado";
      showToast("El conductor aceptó tu solicitud");
    }
    if(d.estado==="rechazado"){
      document.getElementById("viaje-ov").classList.remove("show");
      activeSolId=null;activeViaje=null;
      if(unsubSol){unsubSol();unsubSol=null;}
      showToast("El conductor no pudo atenderte — intenta de nuevo");
    }
  });
  onValue(ref(db,"unidades/"+unitId+"/status"),snap=>{
    const s=snap.val();
    if(s&&s.toLowerCase()!=="ocupado"&&activeViaje&&activeViaje.unitId===unitId){
      setTimeout(()=>{if(activeViaje)mostrarRating();},1500);
    }
  });
}
window.cancelarSolicitud=async function(){
  if(activeSolId){try{await updateDoc(doc(fs,"solicitudes",activeSolId),{estado:"cancelado",activa:false,actualizadoEn:serverTimestamp()});}catch(e){console.warn(e);}activeSolId=null;}
  if(unsubSol){unsubSol();unsubSol=null;}activeViaje=null;
  document.getElementById("viaje-ov").classList.remove("show");showToast("Solicitud cancelada");
};
function mostrarRating(){
  if(!activeViaje)return;
  rateData={...activeViaje};activeViaje=null;activeSolId=null;
  if(unsubSol){unsubSol();unsubSol=null;}
  document.getElementById("viaje-ov").classList.remove("show");
  document.getElementById("rate-sub").textContent="Califica a "+(rateData.conductor||"tu conductor");
  document.getElementById("rate-ov").classList.add("show");
}
window.rateStar=function(n){star=n;document.querySelectorAll(".star").forEach((s,i)=>s.classList.toggle("on",i<n));};
window.enviarRating=async function(){
  if(rateData){try{await addDoc(collection(fs,"calificaciones"),{unitId:rateData.unitId,rating:star,clienteNombre:myName,ts:serverTimestamp()});}catch(e){push(ref(db,"calificaciones"),{unitId:rateData.unitId,rating:star,cliente:myName,ts:Date.now()});}}
  document.getElementById("rate-ov").classList.remove("show");showToast("Gracias por tu calificacion!");
};
function renderHist(){const el=document.getElementById("hist-list");el.innerHTML=historial.length?historial.slice().reverse().map(h=>`<div class="hist-item"><div class="hist-dest">📍 ${h.destino}</div><div class="hist-meta">🚖 ${h.unitId} — ${h.conductor||"Conductor"} · ${new Date(h.ts).toLocaleString("es",{day:"numeric",month:"short",hour:"2-digit",minute:"2-digit"})}</div></div>`).join(""):"<div style=\"text-align:center;color:#9ca3af;padding:40px\">Sin viajes aun</div>";}
function showToast(m){const t=document.getElementById("toast");t.textContent=m;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),3000);}
window.switchNav=function(s,btn){document.querySelectorAll(".screen").forEach(x=>x.classList.remove("active"));document.querySelectorAll(".nav-btn").forEach(b=>b.classList.remove("active"));document.getElementById("screen-"+s).classList.add("active");btn.classList.add("active");if(s==="historial")renderHist();};
</script>
</body>
</html>